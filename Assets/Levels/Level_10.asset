  m_Script: {fileID: 11500000, guid: 563ba62e737be404aafce490e44bc8a7, type: 3}
  m_Name: Level_10
  m_EditorClassIdentifier: Assembly-CSharp::LevelConfig
  backgroundSprite: {fileID: 21300000, guid: 4d8dd74a5a0e06d45a533e980646557c, type: 3}
  timePerQuestion: 7
  questions:
  - questionText: "\u041A\u0430\u043A\u043E\u0435 \u0441\u043B\u043E\u0432\u043E
      \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u043F\u0430\u043B\u0438\u043D\u0434\u0440\u043E\u043C\u043E\u043C
      (\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F \u043E\u0434\u0438\u043D\u0430\u043A\u043E\u0432\u043E
      \u0432 \u043E\u0431\u0435 \u0441\u0442\u043E\u0440\u043E\u043D\u044B)?"
    answers:
    - "\u0448\u043A\u043E\u043B\u0430"
    - "\u0442\u043E\u043F\u043E\u0442"
    - "\u0443\u0447\u0438\u043B\u043A\u0430"
    correctAnswerIndex: 1
  - questionText: "\u0427\u0442\u043E \u0431\u044B\u0441\u0442\u0440\u0435\u0435
      \u0438\u0441\u043F\u043E\u0440\u0442\u0438\u0442\u0441\u044F \u0431\u0435\u0437
      \u0445\u043E\u043B\u043E\u0434\u0438\u043B\u044C\u043D\u0438\u043A\u0430?"
    answers:
    - "\u0421\u0430\u0445\u0430\u0440"
    - "\u0421\u044B\u0440\u043E\u0435 \u043C\u044F\u0441\u043E"
    - "\u0421\u043E\u043B\u044C"
    correctAnswerIndex: 1
  - questionText: "\u0415\u0441\u043B\u0438 \u0447\u0435\u043B\u043E\u0432\u0435\u043A
      \u0443\u0432\u0435\u0440\u0435\u043D \u0438 \u0433\u043E\u0432\u043E\u0440\u0438\u0442
      \u0433\u0440\u043E\u043C\u043A\u043E, \u044D\u0442\u043E \u0437\u043D\u0430\u0447\u0438\u0442\u2026"
    answers:
    - "\u042D\u0442\u043E \u043D\u0435 \u043F\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C
      \u043F\u0440\u0430\u0432\u043E\u0442\u044B"
    - "\u041E\u043D \u043F\u0440\u0430\u0432"
    - "\u041E\u043D \u0443\u0447\u0438\u0442\u0435\u043B\u044C"
    correctAnswerIndex: 0
  - questionText: "\u201C\u0412\u0441\u0435 \u0443\u0447\u0435\u043D\u0438\u043A\u0438,
      \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043E\u043F\u043E\u0437\u0434\u0430\u043B\u0438,
      \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0438 \u0437\u0430\u043C\u0435\u0447\u0430\u043D\u0438\u0435.\u201D
      \u0412\u0435\u0440\u043D\u043E \u043B\u0438, \u0447\u0442\u043E \u201C\u0432\u0441\u0435
      \u043F\u043E\u043B\u0443\u0447\u0438\u0432\u0448\u0438\u0435 \u0437\u0430\u043C\u0435\u0447\u0430\u043D\u0438\u0435
      \u043E\u043F\u043E\u0437\u0434\u0430\u043B\u0438\u201D?"
    answers:
    - "\u041E\u0431\u044F\u0437\u0430\u0442\u0435\u043B\u044C\u043D\u043E"
    - "\u0414\u0430"
    - "\u041D\u0435\u0442, \u043D\u0435 \u0441\u043B\u0435\u0434\u0443\u0435\u0442"
    correctAnswerIndex: 2
  - questionText: "\u041A\u0430\u043A\u0430\u044F \u043F\u043B\u0430\u043D\u0435\u0442\u0430
      \u0438\u043C\u0435\u0435\u0442 \u0441\u0430\u043C\u044B\u0435 \u0437\u0430\u043C\u0435\u0442\u043D\u044B\u0435
      \u043A\u043E\u043B\u044C\u0446\u0430?"
    answers:
    - "\u042E\u043F\u0438\u0442\u0435\u0440"
    - "\u0421\u0430\u0442\u0443\u0440\u043D"
    - "\u041C\u0430\u0440\u0441"
    correctAnswerIndex: 1
  - questionText: "\u0427\u0442\u043E \u0442\u0430\u043A\u043E\u0435 \u0441\u0432\u0435\u0442\u043E\u0432\u043E\u0439
      \u0433\u043E\u0434?"
    answers:
    - "\u0412\u0440\u0435\u043C\u044F"
    - "\u0420\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u0435"
    - "\u042F\u0440\u043A\u043E\u0441\u0442\u044C"
    correctAnswerIndex: 1
  - questionText: "\u0413\u0434\u0435 \u043D\u0430 \u0417\u0435\u043C\u043B\u0435
      \u043F\u043E\u043B\u044F\u0440\u043D\u044B\u0439 \u0434\u0435\u043D\u044C \u0432\u043E\u0437\u043C\u043E\u0436\u0435\u043D?"
    answers:
    - "\u041D\u0430 \u044D\u043A\u0432\u0430\u0442\u043E\u0440\u0435"
    - "\u0412 \u043F\u0443\u0441\u0442\u044B\u043D\u044F\u0445"
    - "\u0417\u0430 \u043F\u043E\u043B\u044F\u0440\u043D\u044B\u043C\u0438 \u043A\u0440\u0443\u0433\u0430\u043C\u0438"
    correctAnswerIndex: 2
  - questionText: "\u041A\u0430\u043A\u0430\u044F \u0433\u0430\u043B\u0430\u043A\u0442\u0438\u043A\u0430
      \u043D\u0430\u0448\u0430?"
    answers:
    - "\u0410\u043D\u0434\u0440\u043E\u043C\u0435\u0434\u0430"
    - "\u041C\u043B\u0435\u0447\u043D\u044B\u0439 \u041F\u0443\u0442\u044C"
    - "\u0422\u0443\u043C\u0430\u043D\u043D\u043E\u0441\u0442\u044C \u041E\u0440\u0438\u043E\u043D\u0430"
    correctAnswerIndex: 1
  - questionText: "\u0427\u0442\u043E \u0442\u0430\u043A\u043E\u0435 \u201C\u043F\u0430\u043C\u044F\u0442\u044C
      \u0443\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u0430\u201D \u0438 \u201C\u043E\u043F\u0435\u0440\u0430\u0442\u0438\u0432\u043D\u0430\u044F
      \u043F\u0430\u043C\u044F\u0442\u044C\u201D \u2014 \u043A\u043B\u044E\u0447\u0435\u0432\u043E\u0435
      \u043E\u0442\u043B\u0438\u0447\u0438\u0435?"
    answers:
    - "\u041E\u0417\u0423 \u0431\u044B\u0441\u0442\u0440\u0435\u0435 \u0438 \u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0430\u044F"
    - "\u041E\u0417\u0423 \u0445\u0440\u0430\u043D\u0438\u0442 \u043D\u0430\u0432\u0441\u0435\u0433\u0434\u0430"
    - "\u041F\u0430\u043C\u044F\u0442\u044C = \u0438\u043D\u0442\u0435\u0440\u043D\u0435\u0442"
    correctAnswerIndex: 0
  - questionText: "\u0427\u0442\u043E \u0442\u0430\u043A\u043E\u0435 \u201C\u043B\u0430\u0442\u0435\u043D\u0442\u043D\u043E\u0441\u0442\u044C\u201D
      \u0432 \u0438\u0433\u0440\u0430\u0445 \u043E\u043D\u043B\u0430\u0439\u043D?"
    answers:
    - "\u0413\u0440\u0430\u0444\u0438\u043A\u0430"
    - "\u0417\u0430\u0434\u0435\u0440\u0436\u043A\u0430 \u0441\u0435\u0442\u0438"
    - "\u0420\u0430\u0437\u043C\u0435\u0440 \u043A\u0430\u0440\u0442\u044B"
    correctAnswerIndex: 1
