  backgroundSprite: {fileID: 21300000, guid: 64416233fc13b7d4c9b7c3bb2db87db4, type: 3}
  timePerQuestion: 8
  questions:
  - questionText: "1 \u043A\u0433 \u0432\u0430\u0442\u044B \u0438\u043B\u0438 1 \u043A\u0433
      \u0436\u0435\u043B\u0435\u0437\u0430?"
    answers:
    - "\u0412\u0430\u0442\u0430"
    - "\u0416\u0435\u043B\u0435\u0437\u043E"
    - "\u041E\u0434\u0438\u043D\u0430\u043A\u043E\u0432\u043E"
    correctAnswerIndex: 2
  - questionText: "\u0412\u044B\u043A\u043B\u044E\u0447\u0438\u043B\u0438 \u0441\u0432\u0435\u0442:
      \u0447\u0442\u043E \u0432\u043A\u043B\u044E\u0447\u0430\u0435\u0442\u0441\u044F
      \u043F\u0435\u0440\u0432\u044B\u043C?"
    answers:
    - "\u042D\u043B\u0435\u043A\u0442\u0440\u0438\u0447\u0435\u0441\u0442\u0432\u043E"
    - "\u041B\u0430\u043C\u043F\u043E\u0447\u043A\u0430"
    - "\u0422\u044C\u043C\u0430"
    correctAnswerIndex: 2
  - questionText: "\u0427\u0442\u043E \u043D\u0435\u043B\u044C\u0437\u044F \u0441\u044A\u0435\u0441\u0442\u044C
      \u043D\u0430 \u0437\u0430\u0432\u0442\u0440\u0430\u043A?"
    answers:
    - "\u041E\u0431\u0435\u0434"
    - "\u0423\u0436\u0438\u043D"
    - "\u0411\u0443\u0442\u0435\u0440\u0431\u0440\u043E\u0434"
    correctAnswerIndex: 0
  - questionText: "\u0423 \u043A\u0430\u043A\u043E\u0439 \u201C\u0440\u044B\u0431\u044B\u201D
      \u043D\u0435\u0442 \u043A\u043E\u0441\u0442\u0435\u0439?"
    answers:
    - "\u0420\u044B\u0431\u0430-\u043F\u0438\u043B\u0430"
    - "\u0420\u044B\u0431\u0430-\u043A\u043B\u043E\u0443\u043D"
    - "\u0420\u044B\u0431\u0430 \u043D\u0430 \u0446\u0435\u043D\u043D\u0438\u043A\u0435"
    correctAnswerIndex: 2
  - questionText: "\u0427\u0442\u043E \u043C\u043E\u0436\u043D\u043E \u0441\u043B\u043E\u043C\u0430\u0442\u044C,
      \u043D\u0435 \u043F\u0440\u0438\u043A\u0430\u0441\u0430\u044F\u0441\u044C?"
    answers:
    - "\u041E\u0431\u0435\u0449\u0430\u043D\u0438\u0435"
    - "\u0421\u0442\u0435\u043A\u043B\u043E"
    - "\u0414\u043E\u0441\u043A\u0443"
    correctAnswerIndex: 0
  - questionText: "\u0427\u0442\u043E \u0440\u0430\u0441\u0442\u0451\u0442, \u0435\u0441\u043B\u0438
      \u0435\u0433\u043E \u043E\u0442\u043D\u044F\u0442\u044C?"
    answers:
    - "\u0414\u043E\u043B\u0433"
    - "\u0422\u0440\u0430\u0432\u0430"
    - "\u0420\u043E\u0441\u0442"
    correctAnswerIndex: 0
  - questionText: "\u041A\u0430\u043A\u043E\u0435 \u0447\u0438\u0441\u043B\u043E
      \u0434\u0435\u043B\u0438\u0442\u0441\u044F \u043D\u0430 \u0432\u0441\u0451?"
    answers:
    - 0
    - 1
    - 10
    correctAnswerIndex: 1
  - questionText: "\u0427\u0442\u043E \u0432\u043F\u0435\u0440\u0435\u0434\u0438,
      \u043D\u043E \u043D\u0435 \u0432\u0438\u0434\u043D\u043E?"
    answers:
    - "\u041D\u043E\u0441"
    - "\u0421\u043F\u0438\u043D\u0430"
    - "\u0417\u0430\u0432\u0442\u0440\u0430"
    correctAnswerIndex: 2
  - questionText: "\u0427\u0442\u043E \u043D\u0443\u0436\u043D\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u044C,
      \u0447\u0442\u043E\u0431\u044B \u0441\u0442\u0430\u043B\u043E \u0437\u0430\u043A\u0440\u044B\u0442\u044B\u043C?"
    answers:
    - "\u0414\u0432\u0435\u0440\u044C"
    - "\u0417\u043E\u043D\u0442"
    - "\u041E\u043A\u043D\u043E"
    correctAnswerIndex: 1
  - questionText: "\u0427\u0442\u043E \u0447\u0430\u0449\u0435 \u0442\u0435\u0440\u044F\u044E\u0442,
      \u043A\u043E\u0433\u0434\u0430 \u0431\u043E\u043B\u044C\u0448\u0435 \u0432\u0441\u0435\u0433\u043E
      \u043D\u0443\u0436\u043D\u043E?"
    answers:
    - "\u0412\u0440\u0435\u043C\u044F"
    - "\u0422\u0435\u043B\u0435\u0444\u043E\u043D"
    - "\u0422\u0435\u0440\u043F\u0435\u043D\u0438\u0435"
    correctAnswerIndex: 0
