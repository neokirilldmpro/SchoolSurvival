  m_Script: {fileID: 11500000, guid: 563ba62e737be404aafce490e44bc8a7, type: 3}
  m_Name: Level_5
  m_EditorClassIdentifier: Assembly-CSharp::LevelConfig
  backgroundSprite: {fileID: 21300000, guid: 62061258bf4fdd3428edecdf76e3a74a, type: 3}
  timePerQuestion: 8
  questions:
  - questionText: "\u0427\u0442\u043E \u0441\u0438\u043B\u044C\u043D\u0435\u0435
      \u0432\u0441\u0435\u0433\u043E \u043F\u0443\u0433\u0430\u0435\u0442 \u0432
      \u201C\u0437\u043B\u043E\u0432\u0435\u0449\u0435\u0439 \u0443\u043B\u044B\u0431\u043A\u0435\u201D?"
    answers:
    - "\u0417\u0443\u0431\u044B"
    - "\u041D\u0435\u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0443\u0435\u043C\u043E\u0441\u0442\u044C"
    - "\u041F\u0440\u0438\u0447\u0451\u0441\u043A\u0430"
    correctAnswerIndex: 1
  - questionText: "\u041A\u0430\u043A \u043D\u0430\u0437\u044B\u0432\u0430\u0435\u0442\u0441\u044F
      \u0441\u0442\u0440\u0430\u0445 \u0432\u044B\u0441\u043E\u0442\u044B?"
    answers:
    - "\u0410\u043A\u0440\u043E\u0444\u043E\u0431\u0438\u044F"
    - "\u0410\u0440\u0430\u0445\u043D\u043E\u0444\u043E\u0431\u0438\u044F"
    - "\u0410\u0433\u043E\u0440\u0430\u0444\u043E\u0431\u0438\u044F"
    correctAnswerIndex: 0
  - questionText: "\u0427\u0442\u043E \u0442\u0430\u043A\u043E\u0435 \u201C\u0434\u0435\u0436\u0430\u0432\u044E\u201D?"
    answers:
    - "\u041F\u043E\u0442\u0435\u0440\u044F \u043F\u0430\u043C\u044F\u0442\u0438"
    - "\u0427\u0443\u0432\u0441\u0442\u0432\u043E \u201C\u044F \u044D\u0442\u043E
      \u0443\u0436\u0435 \u0432\u0438\u0434\u0435\u043B\u201D"
    - "\u0421\u0442\u0440\u0430\u0445 \u0442\u0435\u043C\u043D\u043E\u0442\u044B"
    correctAnswerIndex: 1
  - questionText: "\u0427\u0442\u043E \u0442\u0430\u043A\u043E\u0435 \u0414\u041D\u041A?"
    answers:
    - "\u0422\u0438\u043F \u0431\u0435\u043B\u043A\u0430"
    - "\u041C\u043E\u043B\u0435\u043A\u0443\u043B\u0430 \u043D\u0430\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
      \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438"
    - "\u0412\u0438\u0434 \u0432\u0438\u0442\u0430\u043C\u0438\u043D\u0430"
    correctAnswerIndex: 1
  - questionText: "\u0427\u0442\u043E \u0442\u0430\u043A\u043E\u0435 \u201C\u0447\u0435\u0440\u043D\u0430\u044F
      \u0434\u044B\u0440\u0430\u201D \u0432 \u043A\u043E\u0441\u043C\u043E\u0441\u0435?"
    answers:
    - "\u0414\u044B\u0440\u0430 \u0432 \u043D\u0435\u0431\u0435"
    - "\u041E\u0431\u044A\u0435\u043A\u0442 \u0441 \u043E\u0447\u0435\u043D\u044C
      \u0441\u0438\u043B\u044C\u043D\u043E\u0439 \u0433\u0440\u0430\u0432\u0438\u0442\u0430\u0446\u0438\u0435\u0439"
    - "\u041F\u0443\u0441\u0442\u043E\u0435 \u043C\u0435\u0441\u0442\u043E \u0431\u0435\u0437
      \u043C\u0430\u0442\u0435\u0440\u0438\u0438"
    correctAnswerIndex: 1
  - questionText: "\u0427\u0442\u043E \u0431\u043E\u043B\u044C\u0448\u0435: 0.5 \u0438\u043B\u0438
      0.05?"
    answers:
    - 0.05
    - 0.5
    - "\u041E\u0434\u0438\u043D\u0430\u043A\u043E\u0432\u043E"
    correctAnswerIndex: 1
  - questionText: "\u0415\u0441\u043B\u0438 \u201C\u0432\u0441\u0435 \u0443\u0447\u0435\u043D\u0438\u043A\u0438
      \u0432 \u043A\u043B\u0430\u0441\u0441\u0435 \u2014 \u043B\u044E\u0434\u0438\u201D,
      \u0432\u0435\u0440\u043D\u043E \u043B\u0438, \u0447\u0442\u043E \u201C\u0432\u0441\u0435
      \u043B\u044E\u0434\u0438 \u2014 \u0443\u0447\u0435\u043D\u0438\u043A\u0438\u201D?"
    answers:
    - "\u0414\u0430"
    - "\u041D\u0435\u0442"
    - "\u0422\u043E\u043B\u044C\u043A\u043E \u043D\u043E\u0447\u044C\u044E"
    correctAnswerIndex: 1
  - questionText: "\u0427\u0442\u043E \u0447\u0430\u0449\u0435 \u0432\u0441\u0435\u0433\u043E
      \u0441\u0442\u0440\u0430\u0448\u043D\u0435\u0435: \u043E\u0448\u0438\u0431\u043A\u0430
      \u0438\u043B\u0438 \u0441\u0442\u0440\u0430\u0445 \u043E\u0448\u0438\u0431\u043A\u0438?"
    answers:
    - "\u041E\u0448\u0438\u0431\u043A\u0430"
    - "\u0421\u0442\u0440\u0430\u0445 \u043E\u0448\u0438\u0431\u043A\u0438"
    - "\u041E\u0434\u0438\u043D\u0430\u043A\u043E\u0432\u043E"
    correctAnswerIndex: 1
  - questionText: "\u041A\u0430\u043A\u0430\u044F \u043F\u0443\u0441\u0442\u044B\u043D\u044F
      \u0441\u0430\u043C\u0430\u044F \u0431\u043E\u043B\u044C\u0448\u0430\u044F \u043F\u043E
      \u043F\u043B\u043E\u0449\u0430\u0434\u0438?"
    answers:
    - "\u0421\u0430\u0445\u0430\u0440\u0430"
    - "\u0410\u043D\u0442\u0430\u0440\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F"
    - "\u0410\u0442\u0430\u043A\u0430\u043C\u0430"
    correctAnswerIndex: 1
  - questionText: "\u201C\u041C\u043E\u043D\u0430 \u041B\u0438\u0437\u0430\u201D
      \u2014 \u0430\u0432\u0442\u043E\u0440?"
    answers:
    - "\u041B\u0435\u043E\u043D\u0430\u0440\u0434\u043E \u0434\u0430 \u0412\u0438\u043D\u0447\u0438"
    - "\u0412\u0430\u043D \u0413\u043E\u0433"
    - "\u041F\u0438\u043A\u0430\u0441\u0441\u043E"
    correctAnswerIndex: 0
