  m_Script: {fileID: 11500000, guid: 563ba62e737be404aafce490e44bc8a7, type: 3}
  m_Name: Level_9
  m_EditorClassIdentifier: Assembly-CSharp::LevelConfig
  backgroundSprite: {fileID: 21300000, guid: a44351a39b10ca844896b33d9c86afbb, type: 3}
  timePerQuestion: 7
  questions:
  - questionText: "\u0427\u0442\u043E \u0447\u0430\u0449\u0435 \u0432\u0441\u0435\u0433\u043E
      \u0432\u044B\u0434\u0430\u0435\u0442 \u043B\u043E\u0436\u044C?"
    answers:
    - "\u0423\u0432\u0435\u0440\u0435\u043D\u043D\u043E\u0441\u0442\u044C"
    - "\u0421\u043B\u0438\u0448\u043A\u043E\u043C \u043C\u043D\u043E\u0433\u043E
      \u0434\u0435\u0442\u0430\u043B\u0435\u0439"
    - "\u0422\u0438\u0448\u0438\u043D\u0430"
    correctAnswerIndex: 1
  - questionText: "\u0427\u0442\u043E \u0441\u0438\u043B\u044C\u043D\u0435\u0435
      \u0441\u0442\u0440\u0430\u0445\u0430?"
    answers:
    - "\u041B\u044E\u0431\u043E\u043F\u044B\u0442\u0441\u0442\u0432\u043E"
    - "\u0422\u0435\u043C\u043D\u043E\u0442\u0430"
    - "\u0428\u0443\u043C"
    correctAnswerIndex: 0
  - questionText: "\u041A\u0430\u043A \u043D\u0430\u0437\u044B\u0432\u0430\u0435\u0442\u0441\u044F
      \u0441\u0442\u0440\u0430\u0445 \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u044B\u0445
      \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432?"
    answers:
    - "\u0410\u0433\u043E\u0440\u0430\u0444\u043E\u0431\u0438\u044F"
    - "\u041A\u043B\u0430\u0443\u0441\u0442\u0440\u043E\u0444\u043E\u0431\u0438\u044F"
    - "\u0410\u043A\u0440\u043E\u0444\u043E\u0431\u0438\u044F"
    correctAnswerIndex: 1
  - questionText: "\u041A\u0430\u043A \u043D\u0430\u0437\u044B\u0432\u0430\u0435\u0442\u0441\u044F
      \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435, \u043A\u043E\u0433\u0434\u0430
      \u0447\u0435\u043B\u043E\u0432\u0435\u043A \u0441\u043B\u044B\u0448\u0438\u0442
      \u0433\u043E\u043B\u043E\u0441\u0430 \u0431\u0435\u0437 \u0432\u043D\u0435\u0448\u043D\u0435\u0433\u043E
      \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0430?"
    answers:
    - "\u0413\u0430\u043B\u043B\u044E\u0446\u0438\u043D\u0430\u0446\u0438\u0438"
    - "\u042D\u0445\u043E"
    - "\u0414\u0435\u0436\u0430\u0432\u044E"
    correctAnswerIndex: 0
  - questionText: "\u201C\u041F\u0430\u0440\u0430\u043B\u0438\u0447 \u0441\u043D\u0430\u201D
      \u2014 \u044D\u0442\u043E \u0447\u0430\u0449\u0435 \u0432\u0441\u0435\u0433\u043E\u2026"
    answers:
    - "\u0420\u0435\u0430\u043B\u044C\u043D\u0430\u044F \u043E\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u0430
      \u0441\u0435\u0440\u0434\u0446\u0430"
    - "\u041F\u0440\u043E\u0441\u043D\u0443\u043B\u0441\u044F \u043C\u043E\u0437\u0433,
      \u043D\u043E \u0442\u0435\u043B\u043E \u0435\u0449\u0451 \u201C\u0441\u043F\u0438\u0442\u201D"
    - "\u041F\u043E\u0442\u0435\u0440\u044F \u043F\u0430\u043C\u044F\u0442\u0438
      \u043D\u0430 \u0441\u0443\u0442\u043A\u0438"
    correctAnswerIndex: 1
  - questionText: "\u041A\u0430\u043A \u043D\u0430\u0437\u044B\u0432\u0430\u0435\u0442\u0441\u044F
      \u201C\u043B\u043E\u0436\u043D\u043E\u0435 \u0432\u043E\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u0435\u201D,
      \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u043A\u0430\u0436\u0435\u0442\u0441\u044F
      \u0440\u0435\u0430\u043B\u044C\u043D\u044B\u043C? "
    answers:
    - "\u041A\u043E\u043D\u0444\u0430\u0431\u0443\u043B\u044F\u0446\u0438\u044F"
    - "\u0424\u043E\u0431\u0438\u044F"
    - "\u0418\u043D\u0442\u0443\u0438\u0446\u0438\u044F"
    correctAnswerIndex: 0
  - questionText: "\u0427\u0442\u043E \u0447\u0430\u0449\u0435 \u0432\u0441\u0435\u0433\u043E
      \u0441\u0438\u043B\u044C\u043D\u0435\u0435 \u043F\u0443\u0433\u0430\u0435\u0442
      \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430: \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0441\u0442\u044C
      \u0438\u043B\u0438 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430\u044F \u043E\u043F\u0430\u0441\u043D\u043E\u0441\u0442\u044C?"
    answers:
    - "\u0418\u0437\u0432\u0435\u0441\u0442\u043D\u0430\u044F"
    - "\u041D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0441\u0442\u044C"
    - "\u041E\u0434\u0438\u043D\u0430\u043A\u043E\u0432\u043E"
    correctAnswerIndex: 1
  - questionText: "\u041F\u043E\u0447\u0435\u043C\u0443 \u043B\u0438\u0446\u043E
      \u043A\u0443\u043A\u043B\u044B \u0438\u043D\u043E\u0433\u0434\u0430 \u043F\u0443\u0433\u0430\u0435\u0442
      \u0441\u0438\u043B\u044C\u043D\u0435\u0435 \u043B\u0438\u0446\u0430 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430?"
    answers:
    - "\u041E\u043D\u043E \u0441\u043B\u0438\u0448\u043A\u043E\u043C \u0437\u043D\u0430\u043A\u043E\u043C\u043E\u0435"
    - "\u041E\u043D\u043E \u201C\u043F\u043E\u0447\u0442\u0438\u201D \u0436\u0438\u0432\u043E\u0435,
      \u043D\u043E \u043D\u0435 \u0436\u0438\u0432\u043E\u0435"
    - "\u041E\u043D\u043E \u0432\u0441\u0435\u0433\u0434\u0430 \u0437\u043B\u043E\u0435"
    correctAnswerIndex: 1
  - questionText: "\u041A\u0430\u043A \u043D\u0430\u0437\u044B\u0432\u0430\u0435\u0442\u0441\u044F
      \u0441\u0442\u0440\u0430\u0445 \u0442\u0435\u043C\u043D\u043E\u0442\u044B?"
    answers:
    - "\u041D\u0438\u043A\u0442\u043E\u0444\u043E\u0431\u0438\u044F"
    - "\u0421\u043E\u0446\u0438\u043E\u0444\u043E\u0431\u0438\u044F"
    - "\u0410\u043A\u0440\u043E\u0444\u043E\u0431\u0438\u044F"
    correctAnswerIndex: 0
  - questionText: "\u041A\u0430\u043A\u043E\u0435 \u0436\u0438\u0432\u043E\u0442\u043D\u043E\u0435
      \u041D\u0415 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u043C\u043B\u0435\u043A\u043E\u043F\u0438\u0442\u0430\u044E\u0449\u0438\u043C?"
    answers:
    - "\u0414\u0435\u043B\u044C\u0444\u0438\u043D"
    - "\u041B\u0435\u0442\u0443\u0447\u0430\u044F \u043C\u044B\u0448\u044C"
    - "\u0410\u043A\u0443\u043B\u0430"
    correctAnswerIndex: 2
