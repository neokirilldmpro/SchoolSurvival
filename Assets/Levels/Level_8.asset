  m_Script: {fileID: 11500000, guid: 563ba62e737be404aafce490e44bc8a7, type: 3}
  m_Name: Level_8
  m_EditorClassIdentifier: Assembly-CSharp::LevelConfig
  backgroundSprite: {fileID: 21300000, guid: 276314c57d9a45449b7c60c4174dadcf, type: 3}
  timePerQuestion: 7
  questions:
  - questionText: "\u0427\u0442\u043E \u043C\u043E\u0436\u043D\u043E \u043F\u043E\u0442\u0435\u0440\u044F\u0442\u044C,
      \u0445\u043E\u0442\u044F \u043E\u043D\u043E \u043F\u0440\u0438 \u0442\u0435\u0431\u0435?"
    answers:
    - "\u0413\u043E\u043B\u043E\u0441"
    - "\u041D\u0435\u0440\u0432\u044B"
    - "\u0420\u0443\u043A\u0438"
    correctAnswerIndex: 1
  - questionText: "\u0427\u0442\u043E \u043C\u043E\u0436\u043D\u043E \u043D\u0430\u043F\u0438\u0441\u0430\u0442\u044C,
      \u043D\u043E \u043D\u0435\u043B\u044C\u0437\u044F \u043F\u0440\u043E\u0447\u0438\u0442\u0430\u0442\u044C?"
    answers:
    - "\u0428\u0438\u0444\u0440"
    - "\u041C\u0443\u0437\u044B\u043A\u0443"
    - "\u0420\u0435\u0446\u0435\u043F\u0442"
    correctAnswerIndex: 1
  - questionText: "\u041A\u0430\u043A\u043E\u0439 \u0448\u043A\u043E\u043B\u044C\u043D\u044B\u0439
      \u043F\u0440\u0435\u0434\u043C\u0435\u0442 \u0447\u0430\u0449\u0435 \u0432\u0441\u0435\u0433\u043E
      \u201C\u043F\u0440\u043E\u043F\u0430\u0434\u0430\u0435\u0442\u201D \u043D\u0430
      \u0443\u0440\u043E\u043A\u0435?"
    answers:
    - "\u0420\u0443\u0447\u043A\u0430"
    - "\u0414\u043E\u0441\u043A\u0430"
    - "\u041E\u043A\u043D\u043E"
    correctAnswerIndex: 0
  - questionText: "\u0427\u0442\u043E \u0443\u0447\u0438\u0442\u0435\u043B\u044F
      \u0447\u0430\u0449\u0435 \u0432\u0441\u0435\u0433\u043E \u043D\u0430\u0437\u044B\u0432\u0430\u044E\u0442
      \u201C\u0441\u0430\u043C\u044B\u043C \u043F\u0440\u043E\u0441\u0442\u044B\u043C\u201D?"
    answers:
    - "\u0421\u0430\u043C\u044B\u0439 \u0441\u043B\u043E\u0436\u043D\u044B\u0439
      \u0432\u043E\u043F\u0440\u043E\u0441"
    - "\u0414\u043E\u043C\u0430\u0448\u043A\u0443"
    - "\u041A\u0430\u043D\u0438\u043A\u0443\u043B\u044B"
    correctAnswerIndex: 0
  - questionText: "\u0427\u0442\u043E \u0442\u0430\u043A\u043E\u0435 \u201C\u0442\u0451\u043C\u043D\u044B\u0435
      \u0432\u0435\u043A\u0430\u201D?"
    answers:
    - "\u041A\u043E\u0433\u0434\u0430 \u043D\u0435 \u0431\u044B\u043B\u043E \u043B\u0430\u043C\u043F\u043E\u0447\u0435\u043A"
    - "\u041F\u0435\u0440\u0438\u043E\u0434, \u043E \u043A\u043E\u0442\u043E\u0440\u043E\u043C
      \u043C\u0430\u043B\u043E \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u043E\u0432"
    - "\u041A\u043E\u0433\u0434\u0430 \u0432\u0441\u0435 \u043D\u043E\u0441\u0438\u043B\u0438
      \u0447\u0451\u0440\u043D\u043E\u0435"
    correctAnswerIndex: 1
  - questionText: "\u0427\u0442\u043E \u0442\u0430\u043A\u043E\u0435 \u201C\u0445\u043E\u043B\u043E\u0434\u043D\u0430\u044F
      \u0432\u043E\u0439\u043D\u0430\u201D?"
    answers:
    - "\u0412\u043E\u0439\u043D\u0430 \u0437\u0438\u043C\u043E\u0439"
    - "\u041F\u0440\u043E\u0442\u0438\u0432\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435
      \u0431\u0435\u0437 \u043F\u0440\u044F\u043C\u044B\u0445 \u043A\u0440\u0443\u043F\u043D\u044B\u0445
      \u0431\u043E\u0451\u0432 \u043C\u0435\u0436\u0434\u0443 \u0441\u0432\u0435\u0440\u0445\u0434\u0435\u0440\u0436\u0430\u0432\u0430\u043C\u0438"
    - "\u0412\u043E\u0439\u043D\u0430 \u0438\u0437-\u0437\u0430 \u043C\u043E\u0440\u043E\u0436\u0435\u043D\u043E\u0433\u043E"
    correctAnswerIndex: 1
  - questionText: "\u0427\u0435\u043C \u043E\u0442\u043B\u0438\u0447\u0430\u0435\u0442\u0441\u044F
      \u043B\u0435\u0433\u0435\u043D\u0434\u0430 \u043E\u0442 \u0444\u0430\u043A\u0442\u0430?"
    answers:
    - "\u041B\u0435\u0433\u0435\u043D\u0434\u0443 \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u044E\u0442,
      \u0444\u0430\u043A\u0442 \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u044E\u0442"
    - "\u041B\u0435\u0433\u0435\u043D\u0434\u0430 \u0432\u0441\u0435\u0433\u0434\u0430
      \u043F\u0440\u0430\u0432\u0434\u0438\u0432\u0435\u0435"
    - "\u0424\u0430\u043A\u0442 \u0432\u0441\u0435\u0433\u0434\u0430 \u0441\u043A\u0443\u0447\u043D\u0435\u0435"
    correctAnswerIndex: 0
  - questionText: "\u041A\u0430\u043A\u043E\u0439 \u0441\u0430\u043C\u044B\u0439
      \u043E\u043F\u0430\u0441\u043D\u044B\u0439 \u0432\u0440\u0430\u0433 \u0433\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0430
      \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438?"
    answers:
    - "\u0412\u043D\u0435\u0448\u043D\u0438\u0439"
    - "\u0412\u043D\u0443\u0442\u0440\u0435\u043D\u043D\u0438\u0439 \u0440\u0430\u0441\u043A\u043E\u043B"
    - "\u041F\u043E\u0433\u043E\u0434\u0430"
    correctAnswerIndex: 1
  - questionText: "\u0427\u0442\u043E \u0447\u0430\u0449\u0435 \u0432\u0441\u0435\u0433\u043E
      \u201C\u043F\u043E\u0431\u0435\u0436\u0434\u0430\u0435\u0442\u201D \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438?"
    answers:
    - "\u0414\u043E\u0431\u0440\u043E"
    - "\u0421\u0438\u043B\u0430"
    - "\u0418\u043D\u0442\u0435\u0440\u0435\u0441\u044B"
    correctAnswerIndex: 2
  - questionText: "\u041F\u043E\u0447\u0435\u043C\u0443 \u0432 \u0434\u0440\u0435\u0432\u043D\u043E\u0441\u0442\u0438
      \u043B\u044E\u0434\u0438 \u0431\u043E\u044F\u043B\u0438\u0441\u044C \u0437\u0430\u0442\u043C\u0435\u043D\u0438\u0439?"
    answers:
    - "\u041F\u043E\u0442\u043E\u043C\u0443 \u0447\u0442\u043E \u0434\u0443\u043C\u0430\u043B\u0438,
      \u0447\u0442\u043E \u044D\u0442\u043E \u0437\u043D\u0430\u043A"
    - "\u041F\u043E\u0442\u043E\u043C\u0443 \u0447\u0442\u043E \u0445\u043E\u043B\u043E\u0434\u043D\u043E"
    - "\u041F\u043E\u0442\u043E\u043C\u0443 \u0447\u0442\u043E \u0441\u0432\u0435\u0442
      \u043B\u043E\u043C\u0430\u043B\u0441\u044F"
    correctAnswerIndex: 0
